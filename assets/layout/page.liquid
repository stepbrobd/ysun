<article lang="en-US" class="prose container mx-auto">
  <h1>{{ title }}</h1>
  <small class="text-nord-9 flex flex-row items-center gap-2">
    <time>{{ created }}<sup class="text-xs text-nord-10">c</sup></time>
    <span>&middot;</span>
    <span>{{ words }} words</span>
    <span>&middot;</span>
    <span>{{ minutes }} min read</span>
    <span class="ml-auto"><time>{{ updated }}<sup class="text-xs text-nord-10">u</sup></time></span>
  </small>
  {{ content }}
  
  {% if pages %}
    <nav class="container mx-auto">
      <hr>
      {% include "assets/layout/list" %}
      <hr>
    </nav>
  {% endif %}
</article>
